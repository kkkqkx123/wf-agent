{
  "name": "@wf-agent/sdk",
  "version": "1.0.0",
  "description": "Modular Agent Framework SDK - Workflow execution engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:watch": "tsc --watch",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --reporter=verbose --exclude '**/e2e/**' --exclude '**/integration/**'",
    "test:integration": "vitest run --config vitest.config.integration.mjs --reporter=verbose",
    "test:e2e": "vitest run --config vitest.config.e2e.mjs --reporter=verbose",
    "test:type": "tsd --files __tests__/test-d",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "agent",
    "workflow",
    "llm",
    "sdk"
  ],
  "author": "Modular Agent Framework Team",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@iarna/toml": "^2.2.5",
    "@wf-agent/common-utils": "workspace:*",
    "@wf-agent/storage": "workspace:*",
    "@wf-agent/types": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "chevrotain": "^12.0.0",
    "fast-ignore": "^2.0.0",
    "isbinaryfile": "^6.0.0",
    "lru-cache": "^11.5.2",
    "minimatch": "^10.2.5",
    "semver": "^7.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/semver": "^7.5.0",
    "tsc-alias": "^1.9.0",
    "tsd": "^0.33.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}