{
  "name": "@wf-agent/server",
  "version": "1.0.0",
  "description": "Modular Agent Framework Unified Server for Web and VSCode WebView",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:watch": "node --watch dist/index.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "server",
    "api",
    "agent",
    "modular-agent",
    "express"
  ],
  "author": "Modular Agent Framework Team",
  "license": "MIT",
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@wf-agent/common-utils": "workspace:*",
    "@wf-agent/runtime": "workspace:*",
    "@wf-agent/sdk": "workspace:*",
    "@wf-agent/types": "workspace:*",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}