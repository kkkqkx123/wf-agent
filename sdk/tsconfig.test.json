{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "index.ts",
    "core/**/*",
    "services/**/*",
    "graph/**/*",
    "agent/**/*",
    "api/**/*",
    "utils/**/*",
    "resources/**/*",
    "workflow/**/*",
    "__tests__/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
