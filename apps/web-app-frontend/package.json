{
  "name": "@wf-agent/web-app-frontend",
  "version": "1.0.0",
  "description": "Modular Agent Framework Web Application Frontend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
  	"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "web",
    "frontend",
    "agent",
    "modular-agent"
  ],
  "author": "Modular Agent Framework Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	}
}