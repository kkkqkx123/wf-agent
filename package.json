{
  "name": "wf-agent-monorepo",
  "version": "1.0.0",
  "description": "Agent with Workflow",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "echo \"Error: no test specified. Use 'pnpm --filter <package-name> test <path>' instead\" && exit 1",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rimraf node_modules",
    "typecheck": "turbo run typecheck",
    "typecheck:tests": "turbo run typecheck:tests",
    "postinstall": "pnpm typecheck"
  },
  "keywords": [
    "agent",
    "workflow",
    "llm",
    "modular",
    "typescript",
    "monorepo"
  ],
  "author": "Modular Agent Framework Team",
  "license": "MIT",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}